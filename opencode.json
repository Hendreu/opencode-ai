{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "mcp": {
    "awslabs.aws-api-mcp-server": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "awslabs.aws_api_mcp_server.server"
      ],
      "environment": {
        "AWS_REGION": "sa-east-1"
      },
      "enabled": true
    },
    "gcloud": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@google-cloud/gcloud-mcp"
      ],
      "enabled": true
    },
    "azure": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@azure/mcp@latest",
        "server",
        "start"
      ],
      "enabled": true
    },
    "lovable-mcp": {
      "type": "local",
      "command": [
        "node",
        "C:\\Users\\rain\\lovable-mcp-server\\enhanced-simple-server.js",
        "--project-path",
        "C:\\Users\\rain"
      ],
      "enabled": true
    },
    "clickup": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.clickup.com/mcp"
      ],
      "enabled": true
    }
  }
}
